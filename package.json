{
  "name": "alexide",
  "version": "0.2.0",
  "description": "An IDE built with Electron and Monaco",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --mac dmg"
  },
  "keywords": [
    "ide",
    "electron",
    "monaco"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "acorn": "^8.16.0",
    "monaco-editor": "^0.52.0",
    "node-pty": "^1.1.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.alexide.app",
    "productName": "AlexIDE",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dmg",
      "icon": "assets/icon.png"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
